{
	"private": true,
	"packageManager": "pnpm@10.30.2",
	"scripts": {
		"build": "pnpm -r --filter @ifi/oh-pi-core --filter @ifi/oh-pi-cli run build",
		"build:fast": "pnpm -r --filter @ifi/oh-pi-core --filter @ifi/oh-pi-cli run build:fast",
		"typecheck": "pnpm -r --filter @ifi/oh-pi-core --filter @ifi/oh-pi-cli run typecheck",
		"verify:completion": "pnpm exec vitest run packages/ant-colony/tests/commands.test.ts",
		"test": "vitest run",
		"lint": "biome check --error-on-warnings .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --write .",
		"check": "biome ci --error-on-warnings ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^22.0.0",
		"@typescript/native-preview": "7.0.0-dev.20260305.1",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
