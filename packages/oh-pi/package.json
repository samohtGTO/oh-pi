{
  "name": "@ifiokjr/oh-pi",
  "version": "0.2.2",
  "description": "One-click setup for pi-coding-agent — extensions, themes, prompts, skills, and ant-colony swarm. Like oh-my-zsh for pi.",
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "configuration",
    "setup",
    "tui"
  ],
  "pi": {
    "extensions": [
      "node_modules/@ifiokjr/oh-pi-extensions/extensions",
      "node_modules/@ifiokjr/oh-pi-ant-colony/extensions"
    ],
    "themes": [
      "node_modules/@ifiokjr/oh-pi-themes/themes"
    ],
    "prompts": [
      "node_modules/@ifiokjr/oh-pi-prompts/prompts"
    ],
    "skills": [
      "node_modules/@ifiokjr/oh-pi-skills/skills"
    ]
  },
  "files": [
    "README.md"
  ],
  "license": "MIT",
  "dependencies": {
    "@ifiokjr/oh-pi-extensions": "workspace:*",
    "@ifiokjr/oh-pi-ant-colony": "workspace:*",
    "@ifiokjr/oh-pi-themes": "workspace:*",
    "@ifiokjr/oh-pi-prompts": "workspace:*",
    "@ifiokjr/oh-pi-skills": "workspace:*",
    "@ifiokjr/oh-pi-agents": "workspace:*"
  },
  "bundleDependencies": false
}