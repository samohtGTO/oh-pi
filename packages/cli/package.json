{
	"name": "@ifi/oh-pi-cli",
	"version": "0.4.4",
	"description": "Interactive TUI configurator for pi-coding-agent.",
	"keywords": [
		"cli",
		"configuration",
		"installer",
		"oh-pi",
		"pi",
		"pi-coding-agent",
		"tui"
	],
	"homepage": "https://github.com/ifiokjr/oh-pi/tree/main/packages/cli",
	"bugs": {
		"url": "https://github.com/ifiokjr/oh-pi/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ifiokjr/oh-pi.git",
		"directory": "packages/cli"
	},
	"bin": {
		"oh-pi": "dist/bin/oh-pi.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist',{ recursive: true, force: true }))\"",
		"build": "pnpm clean && tsc -b",
		"build:fast": "pnpm clean && tsgo --project tsconfig.json",
		"typecheck": "tsgo --project tsconfig.json --noEmit",
		"test": "vitest run",
		"start": "node dist/bin/oh-pi.js"
	},
	"dependencies": {
		"@clack/prompts": "^1.1.0",
		"@ifi/oh-pi-agents": "0.4.4",
		"@ifi/oh-pi-ant-colony": "0.4.4",
		"@ifi/oh-pi-core": "0.4.4",
		"@ifi/oh-pi-extensions": "0.4.4",
		"@ifi/oh-pi-prompts": "0.4.4",
		"@ifi/oh-pi-skills": "0.4.4",
		"@ifi/oh-pi-themes": "0.4.4",
		"@ifi/pi-extension-subagents": "0.4.4",
		"@ifi/pi-plan": "0.4.4",
		"@ifi/pi-shared-qna": "0.4.4",
		"@ifi/pi-spec": "0.4.4",
		"chalk": "^5.6.2"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
