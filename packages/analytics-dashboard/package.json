{
	"name": "@ifi/pi-analytics-dashboard",
	"version": "0.4.4",
	"private": true,
	"description": "Pi Analytics Dashboard - Visualize your AI usage",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:server": "npx tsx src/server/index.ts",
		"dev:full": "concurrently \"vite\" \"npx tsx src/server/index.ts\"",
		"build": "vite build",
		"build:check": "tsc && vite build",
		"build:fast": "vite build",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@ifi/pi-analytics-db": "0.4.4",
		"@tanstack/react-query": "^5.74.0",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"lucide-react": "^0.487.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"recharts": "^2.15.0",
		"tailwind-merge": "^3.2.0",
		"zustand": "^5.0.3"
	},
	"devDependencies": {
		"@playwright/test": "^1.52.0",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.1",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.0",
		"@types/react": "^19.1.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "4",
		"@vitest/browser-playwright": "^4.1.4",
		"@vitest/coverage-v8": "^4.1.4",
		"autoprefixer": "^10.4.21",
		"concurrently": "^9.1.0",
		"cors": "^2.8.5",
		"express": "^5.1.0",
		"jsdom": "^26.1.0",
		"oxlint": "^0.16.0",
		"playwright": "^1.59.1",
		"postcss": "^8.5.3",
		"tailwindcss": "^4.1.0",
		"tsx": "^4.19.0",
		"typescript": "^5.8.0",
		"vite": "^8.0.0",
		"vitest": "^4.1.4"
	}
}
