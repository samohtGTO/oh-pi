{
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 120,
	"singleQuote": false,
	"jsxSingleQuote": false,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"semi": true,
	"arrowParens": "always",
	"bracketSameLine": false,
	"bracketSpacing": true,
	"ignorePatterns": [
		"**/node_modules/**",
		"**/dist/**",
		"**/build/**",
		"**/coverage/**",
		"**/.changeset/**",
		"**/*.min.js",
		"**/pnpm-lock.yaml",
		"**/package-lock.json",
		"**/yarn.lock"
	]
}
