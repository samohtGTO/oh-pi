{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "oxc", "jsdoc", "jest", "vitest", "promise"],
	"categories": {
		"correctness": "error",
		"suspicious": "error",
		"pedantic": "off",
		"style": "off",
		"nursery": "off",
		"restriction": "off"
	},
	"rules": {
		"typescript/no-explicit-any": "off",
		"no-console": "off",
		"require-await": "off",
		"no-inline-comments": "off",
		"no-negated-condition": "off",
		"max-depth": "off",
		"max-classes-per-file": "off",
		"no-shadow": "off",
		"no-unused-vars": "off",
		"no-control-regex": "off",
		"vitest/require-mock-type-parameters": "off",
		"jest/valid-title": "off",
		"jest/no-conditional-expect": "off",
		"jest/no-standalone-expect": "off",
		"jest/expect-expect": "off",
		"jest/valid-expect": "off",
		"jest/require-to-throw-message": "off",
		"promise/always-return": "off",
		"promise/no-multiple-resolved": "off",
		"promise/no-callback-in-promise": "off",
		"typescript/no-extraneous-class": "off",
		"typescript/no-unsafe-type-assertion": "off",
		"typescript/no-unnecessary-type-assertion": "off",
		"typescript/consistent-return": "off",
		"typescript/no-unnecessary-type-conversion": "off",
		"typescript/no-unnecessary-template-expression": "off",
		"typescript/no-redundant-type-constituents": "off",
		"typescript/no-unnecessary-type-parameters": "off",
		"typescript/no-unnecessary-boolean-literal-compare": "off",
		"typescript/require-array-sort-compare": "off",
		"typescript/no-unnecessary-type-arguments": "off",
		"typescript/no-unnecessary-condition": "off",
		"no-unnecessary-condition": "off"
	},
	"env": {
		"builtin": true,
		"node": true,
		"es2024": true
	},
	"ignorePatterns": [
		"**/node_modules/**",
		"**/dist/**",
		"**/build/**",
		"**/coverage/**",
		"**/.changeset/**",
		"**/*.min.js",
		"**/pnpm-lock.yaml",
		"**/package-lock.json",
		"**/yarn.lock",
		"packages/analytics-dashboard/e2e/*.spec.ts",
		"packages/analytics-dashboard/e2e/*.ts",
		"packages/analytics-dashboard/tsconfig.json",
		"packages/analytics-dashboard/tsconfig.node.json",
		"packages/docs/tsconfig.json",
		"packages/docs/tsconfig.node.json"
	],
	"overrides": [
		{
			"files": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx", "benchmarks/**/*.ts"],
			"rules": {
				"no-explicit-any": "off"
			}
		}
	]
}
